{
  "title": "SACT Scheduler — runtime",
  "uid": "sact-scheduler-runtime",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "App ready",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
      "targets": [
        {"expr": "sact_app_ready", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "READY", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests / sec (by status)",
      "gridPos": {"x": 4, "y": 0, "w": 10, "h": 8},
      "targets": [
        {
          "expr": "sum by (status) (rate(sact_http_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 request latency (by endpoint)",
      "gridPos": {"x": 14, "y": 0, "w": 10, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(sact_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error rate (5xx / total)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(sact_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(sact_http_requests_total[5m]))",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Optimiser p95 solve time (by solver)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (solver, le) (rate(sact_optimizer_solve_seconds_bucket[5m])))",
          "legendFormat": "{{solver}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ML p95 prediction latency (by model)",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(sact_ml_prediction_seconds_bucket[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
