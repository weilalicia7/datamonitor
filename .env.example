# ============================================================================
# SACT Scheduler — environment template
# ============================================================================
# Copy this file to `.env` for local development (gitignored, never committed).
# For production, inject these variables via your secrets backend (AWS Secrets
# Manager / HashiCorp Vault / Kubernetes Secrets).  Never hand-paste real
# secrets into source control.
#
# See SECURITY.md + docs/PRODUCTION_READINESS_PLAN.md for the full protocol.
# ============================================================================

# ----------------------------------------------------------------------------
# Flask — session secret (T1.3)
# ----------------------------------------------------------------------------
# Required in any environment that serves requests.  Generate with:
#     python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-with-secrets-token_hex-32

# ----------------------------------------------------------------------------
# Authentication + authorisation (T4.1)
# ----------------------------------------------------------------------------
# Set AUTH_ENABLED=true to enforce role-based access on every mutating route.
# Leave unset (or false) during development — every decorator becomes a no-op.
AUTH_ENABLED=false

# Password-based identities (browser + session auth).  At least one seed should
# be set when AUTH_ENABLED=true; otherwise every request returns 401.
AUTH_SEED_ADMIN_PASSWORD=
AUTH_SEED_OPERATOR_PASSWORD=
AUTH_SEED_VIEWER_PASSWORD=

# API-key identities (machine-to-machine via X-API-Key header).  Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_ADMIN_API_KEY=
AUTH_OPERATOR_API_KEY=
AUTH_VIEWER_API_KEY=

# ----------------------------------------------------------------------------
# CSRF + session cookie hardening (T4.3)
# ----------------------------------------------------------------------------
# CSRF defaults ON.  Flip to false only for local API smoke tests.
CSRF_ENABLED=true

# Session-cookie attributes.
#  - HTTPONLY should stay true in every environment (XSS defence).
#  - SAMESITE: Strict (default), Lax, or None.  None requires SECURE=true.
#  - SECURE: MUST be true in production (HTTPS-only cookies).  Leave
#    unset / false for local HTTP dev.
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_COOKIE_SECURE=false

# Idle session TTL in seconds (30 min default).
SESSION_LIFETIME_SECONDS=1800

# ----------------------------------------------------------------------------
# Input caps + rate limiting (T4.2)
# ----------------------------------------------------------------------------
# Flask-Limiter gate — leave unset in dev (tests don't tolerate 429s).
RATE_LIMIT_ENABLED=false

# Storage backend for Flask-Limiter counters.  memory:// is fine for a single
# worker; for multi-worker / multi-pod deployments use redis://... .
# RATE_LIMIT_STORAGE_URI=memory://

# Per-key cap override example — uncomment to tighten a specific bound.
# VALIDATOR_CAP_HORIZON_DAYS=90
# VALIDATOR_CAP_N_SCENARIOS=200

# ----------------------------------------------------------------------------
# External APIs
# ----------------------------------------------------------------------------
# TomTom traffic API — used by monitoring/traffic_monitor.py for travel-time
# fallback.  Free tier at https://developer.tomtom.com/
TOMTOM_API_KEY=

# ----------------------------------------------------------------------------
# Structured logging + audit trail (T4.4)
# ----------------------------------------------------------------------------
# Log format: `text` (human-readable, dev default) or `json` (for container
# log aggregators — one JSON object per line).
LOG_FORMAT=text

# Patient-ID redaction: default ON (all IDs masked as [REDACTED]).  Flip to
# `true` only in tightly scoped debug sessions.
LOG_PATIENT_IDS=false

# Audit trail directory (append-only JSONL files, one per day).  Retention
# handled by the data-protection playbook (T4.8); do NOT commit.
AUDIT_LOG_DIR=data_cache/audit

# ----------------------------------------------------------------------------
# Observability (T4.5)
# ----------------------------------------------------------------------------
# Uncomment when OpenTelemetry is wired in.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=sact-scheduler

# ----------------------------------------------------------------------------
# Data protection (T4.8)
# ----------------------------------------------------------------------------
# Number of days before per-patient event caches are auto-deleted.
EVENT_RETENTION_DAYS=30
